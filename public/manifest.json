{
  "manifest_version": 3,
  "name": "Bookmark Curator",
  "description": "AI-assisted bookmark cleanup, backup, link checking, and organization.",
  "version": "0.1.0",
  "action": {
    "default_title": "Bookmark Curator"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "side_panel": {
    "default_path": "panel.html"
  },
  "permissions": [
    "alarms",
    "bookmarks",
    "downloads",
    "sidePanel",
    "scripting",
    "storage",
    "tabs",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "http://localhost:8317/*",
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
